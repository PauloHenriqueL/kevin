SECRET_KEY=django-insecure-troque-isso-em-producao
DEBUG=True
ALLOWED_HOSTS=*

# ── Banco de Dados ──────────────────────────
# SQLite (dev local sem Docker):
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=

# PostgreSQL (com Docker), padrão:
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bebelingue
DB_USER=bebelingue
DB_PASSWORD=bebelingue_dev
DB_HOST=db
DB_PORT=5432

# ── Redis + Celery ──────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Provedores de IA / Voz (opcional em dev) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
